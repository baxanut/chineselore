<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — Smart Camera Tracker</title>
  <link rel="stylesheet" href="/styles.css">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    .auth-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .auth-card {
      background: #16213e;
      border: 1px solid #2d3561;
      border-radius: 16px;
      padding: 50px 45px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      animation: slideUp 0.4s ease;
    }
    .auth-logo { text-align: center; margin-bottom: 35px; }
    .auth-logo h1 { font-size: 1.8rem; color: #9d4edd; font-weight: 500; margin-bottom: 6px; }
    .auth-logo p { color: #a0a0a0; font-size: 0.9rem; }
    .auth-form .form-group { margin-bottom: 20px; }
    .auth-form label {
      display: block; color: #c77dff; font-size: 0.85rem;
      font-weight: 500; margin-bottom: 8px;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .auth-form input {
      width: 100%; padding: 13px 18px; background: #0f1624;
      border: 2px solid #2d3561; border-radius: 8px;
      color: #e0e0e0; font-size: 1rem; font-family: 'Roboto', sans-serif;
      transition: all 0.3s ease;
    }
    .auth-form input:focus {
      outline: none; border-color: #9d4edd;
      box-shadow: 0 0 0 3px rgba(157,78,221,0.2);
    }
    .auth-form input::placeholder { color: #4a4a6a; }
    .auth-form small { color: #666; font-size: 0.8rem; margin-top: 5px; display: block; }
    .auth-submit {
      width: 100%; padding: 14px; background: #9d4edd;
      color: white; border: none; border-radius: 8px;
      font-size: 1rem; font-weight: 500; font-family: 'Roboto', sans-serif;
      cursor: pointer; transition: all 0.3s ease; margin-top: 10px;
    }
    .auth-submit:hover {
      background: #7b2cbf; transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(157,78,221,0.4);
    }
    .auth-footer { text-align: center; margin-top: 25px; color: #666; font-size: 0.85rem; }
    .auth-footer a { color: #c77dff; text-decoration: none; }
    .auth-footer a:hover { text-decoration: underline; }
    .auth-error {
      background: #3a1e1e; color: #f48fb1;
      border-left: 4px solid #dc3545;
      padding: 12px 16px; border-radius: 6px;
      margin-bottom: 20px; font-size: 0.9rem;
    }
    .auth-success {
      background: #1e3a20; color: #7bc67e;
      border-left: 4px solid #4caf50;
      padding: 12px 16px; border-radius: 6px;
      margin-bottom: 20px; font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <div class="auth-wrapper">
    <div class="auth-card">
      <div class="auth-logo">
        <h1>📹 MemoryRetrieve</h1>
        <p>Create your account</p>
      </div>
      <% if (error) { %>
        <div class="auth-error">⚠️ <%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="auth-success">✅ <%= success %></div>
      <% } %>
      <form class="auth-form" method="POST" action="/register">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username"
            placeholder="Choose a username" autocomplete="username" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password"
            placeholder="At least 8 characters" autocomplete="new-password" required>
        </div>
        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword"
            placeholder="Repeat your password" autocomplete="new-password" required>
        </div>
        <div class="form-group">
          <label for="invite_code">Invite Code</label>
          <input type="text" id="invite_code" name="invite_code"
            placeholder="Enter invite code" required>
          <small>Ask the system admin for an invite code.</small>
        </div>
        <button type="submit" class="auth-submit">Create Account</button>
      </form>
      <div class="auth-footer">
        Already have an account? <a href="/login">Sign in</a>
      </div>
    </div>
  </div>
</body>
</html>
